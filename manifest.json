{
  "manifest_version": 3,
  "name": "All-in-One Video Enhancer (AIVE)",
  "version": "1.0.0",
  "description": "Video filters + reliable quick-zoom (hold Z) on any HTML5 video.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
    "action": {
    "default_title": "AIVE",
    "default_icon": {
      "16": "icons/brand-16.png",
      "32": "icons/brand-32.png",
      "48": "icons/brand-48.png"
    }
  },
  "icons": {
    "16": "icons/brand-16.png",
    "32": "icons/brand-32.png",
    "48": "icons/brand-48.png",
    "128": "icons/brand-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content-minimal.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}