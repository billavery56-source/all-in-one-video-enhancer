{
    "manifest_version":  3,
    "name":  "All-in-One Video Enhancer (AIVE)",
    "version":  "1.0.4",
    "description":  "Video filters, glare/depth controls, and reliable quick-zoom (hold Z) on HTML5 video.",
    "permissions":  [
                        "storage",
                        "activeTab"
                    ],
    "host_permissions":  [
                             "\u003call_urls\u003e"
                         ],
    "action":  {
                   "default_title":  "AIVE",
                   "default_icon":  {
                                        "16":  "icons/brand-16.png",
                                        "32":  "icons/brand-32.png",
                                        "48":  "icons/brand-48.png"
                                    }
               },
    "background":  {
                       "service_worker":  "sw.js"
                   },
    "commands":  {
                     "aive_open_blacklist":  {
                                                 "suggested_key":  {
                                                                       "default":  "Alt+Shift+B"
                                                                   },
                                                 "description":  "Open AIVE Blacklist Manager"
                                             }
                 },
    "icons":  {
                  "16":  "icons/brand-16.png",
                  "32":  "icons/brand-32.png",
                  "48":  "icons/brand-48.png",
                  "128":  "icons/brand-128.png"
              },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "\u003call_urls\u003e"
                                            ],
                                "js":  [
                                           "scripts/content-minimal.js"
                                       ],
                                "run_at":  "document_idle",
                                "all_frames":  true,
                                "match_origin_as_fallback":  true,
                                "exclude_matches":  [
                                                        "*://chatgpt.com/*",
                                                        "*://*.chatgpt.com/*",
                                                        "*://chat.openai.com/*"
                                                    ]
                            }
                        ]
}
